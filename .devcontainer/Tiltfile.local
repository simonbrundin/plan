# ------------------------------------------------------------------
# Local Development Mode
# Runs database in Docker, frontend locally
# ------------------------------------------------------------------

# ------------------------------------------------------------------
# Docker Compose Setup
# ------------------------------------------------------------------

# Ladda backend services (postgres) från dedikerad compose-fil
docker_compose('./docker-compose.backend.yml')

# ------------------------------------------------------------------
# PostgreSQL Database
# ------------------------------------------------------------------

dc_resource(
  'postgres',
  labels=['Database'],
)

# ------------------------------------------------------------------
# Frontend (Nuxt Dev Server) - körs lokalt
# ------------------------------------------------------------------

local_resource(
  'Nuxt Dev Server',
  serve_cmd=[
    'bash', '-c',
    'cd ../src/nuxt && ' +
    'set -a && source .env && set +a && ' +
    'bun run dev --host'
  ],
  links=['http://localhost:3000'],
  labels=['Frontend'],
  resource_deps=['postgres'],  # Vänta på PostgreSQL
)
