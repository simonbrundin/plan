# ------------------------------------------------------------------
# Local Development Mode
# Runs database and backend in Docker, frontend locally
# ------------------------------------------------------------------

# ------------------------------------------------------------------
# Docker Compose Setup
# ------------------------------------------------------------------

# Ladda backend services (postgres + hasura) från dedikerad compose-fil
docker_compose('./docker-compose.backend.yml')

# ------------------------------------------------------------------
# PostgreSQL Database
# ------------------------------------------------------------------

dc_resource(
  'postgres',
  labels=['Database'],
)

# ------------------------------------------------------------------
# Hasura GraphQL Engine
# ------------------------------------------------------------------

dc_resource(
  'hasura',
  labels=['Backend'],
  links=['http://localhost:8080/console'],
)

# ------------------------------------------------------------------
# Frontend (Nuxt Dev Server) - körs lokalt
# ------------------------------------------------------------------

local_resource(
  'Nuxt Dev Server',
  serve_cmd=[
    'bash', '-c',
    'cd ../frontend && ' +
    'NUXT_SESSION_PASSWORD=5c3ddb48cdb04a05aed90cdb9330cbc2 ' +
    'DATABASE_URL=postgresql://plan:plan@localhost:5432/plan ' +
    'GQL_HOST=http://localhost:8080/v1/graphql ' +
    'HASURA_GRAPHQL_ADMIN_SECRET=dev-admin-secret ' +
    'source .env && ' +
    'NUXT_OAUTH_ZITADEL_CLIENT_ID=$NUXT_OAUTH_ZITADEL_CLIENT_ID ' +
    'NUXT_OAUTH_ZITADEL_DOMAIN=$NUXT_OAUTH_ZITADEL_DOMAIN ' +
    'bun run dev --host'
  ],
  links=['http://localhost:3000'],
  labels=['Frontend'],
  resource_deps=['postgres', 'hasura'],  # Vänta på backend
)

# ------------------------------------------------------------------
# Drizzle Studio
# ------------------------------------------------------------------

local_resource(
  'Drizzle Studio',
  serve_cmd='cd ../frontend && bun run db:studio',
  links=['https://local.drizzle.studio'],
  labels=['Database'],
  resource_deps=['postgres'],  # Vänta på PostgreSQL
)
